imgui.OnInitialize(function()
    imgui.GetIO().IniFilename = nil
    imgui.GetStyle():ScaleAllSizes(MDS)
    fa.Init(14*MDS)
    Style()
end)

--=============================================================
-- \xd5\xf3\xea\xe8 RakLua
--=============================================================

local function writeBsField(bs, t, val)
    if     t:find("float")  then bs:writeFloat(val[0])
    elseif t:find("uint8")  then bs:writeUInt8(val[0])
    elseif t:find("uint16") then bs:writeUInt16(val[0])
    elseif t:find("uint32") then bs:writeUInt32(val[0])
    elseif t:find("int8")   then bs:writeInt8(val[0])
    elseif t:find("int16")  then bs:writeInt16(val[0])
    elseif t:find("int32")  then bs:writeInt32(val[0])
    elseif t:find("string") then
        local s = u8:decode(str(val))
        if t:find("8") then bs:writeUInt8(#s) else bs:writeUInt32(#s) end
        bs:writeString(s)
    elseif t:find("encoded") then bs:writeEncoded(u8:decode(str(val)))
    elseif t:find("bool")   then bs:writeBool(val[0])
    end
end

local function applyHook(bs, hookSlots, bsData)
    bs:resetWritePointer()
    for i=1,#bsData do
        if hookSlots[i] then writeBsField(bs, bsData[i].type, hookSlots[i][3]) end
    end
end

-- \xc8\xf1\xf5. RPC
RakLua.registerHandler(RakLuaEvents.OUTGOING_RPC, function(id,bs,p,r,o,s)
    -- \xef\xee\xe8\xf1\xea /rak \xe2 \xf0\xf3\xf7\xed\xee\xe9 \xea\xee\xec\xe0\xed\xe4\xe5
    if id==50 then
        local ok2, len = pcall(function() return bs:readUInt32() end)
        if ok2 then
            local ok3, cmd = pcall(function() return bs:readString(len) end)
            if ok3 and cmd=="/rak" then config.mainWindow[0]=not config.mainWindow[0]; return false end
        end
    end

    -- \xef\xe5\xf0\xe5\xf5\xe2\xe0\xf2 ID
    if capturingEnabled[0] then
        capturedIDs.rpc_out[#capturedIDs.rpc_out+1] = { id=id, time=getTime() }
        if #capturedIDs.rpc_out > 50 then table.remove(capturedIDs.rpc_out,1) end
    end

    for _,v in ipairs(OUTCOMING_RPC) do
        if id==v[1] then
            if v.nop then return false end
            if v.hook and RakNet.hook.outrpc.selected then
                local data = getBitstream(OUTCOMING_RPC[RakNet.hook.outrpc.selected])
                applyHook(bs, RakNet.hook.outrpc.slots, data)
                return {id,bs,p,r,o,s}
            end
        end
    end
end)

-- \xc2\xf5. RPC
RakLua.registerHandler(RakLuaEvents.INCOMING_RPC, function(id,bs)
    if capturingEnabled[0] then
        capturedIDs.rpc_in[#capturedIDs.rpc_in+1] = { id=id, time=getTime() }
        if #capturedIDs.rpc_in > 50 then table.remove(capturedIDs.rpc_in,1) end
    end
    for _,v in ipairs(INCOMING_RPC) do
        if id==v[1] then
            if v.nop then return false end
            if v.hook and RakNet.hook.inrpc.selected then
                local data = getBitstream(INCOMING_RPC[RakNet.hook.inrpc.selected])
                applyHook(bs, RakNet.hook.inrpc.slots, data)
                return {id,bs}
            end
        end
    end
end)

-- \xc8\xf1\xf5. \xef\xe0\xea\xe5\xf2
RakLua.registerHandler(RakLuaEvents.OUTGOING_PACKET, function(id,bs,p,r,o,s)
    if capturingEnabled[0] then
        capturedIDs.pkt_out[#capturedIDs.pkt_out+1] = { id=id, time=getTime() }
        if #capturedIDs.pkt_out > 50 then table.remove(capturedIDs.pkt_out,1) end
    end
    for _,v in ipairs(OUTCOMING_PACKET) do
        if id==v[1] then
            if v.nop then return false end
            if v.hook and RakNet.hook.outpacket.selected then
                local data = getBitstream(OUTCOMING_PACKET[RakNet.hook.outpacket.selected])
                applyHook(bs, RakNet.hook.outpacket.slots, data)
                return {id,bs,p,r,o,s}
            end
        end
    end
end)

-- \xc2\xf5. \xef\xe0\xea\xe5\xf2
RakLua.registerHandler(RakLuaEvents.INCOMING_PACKET, function(id,bs)
    if capturingEnabled[0] then
        capturedIDs.pkt_in[#capturedIDs.pkt_in+1] = { id=id, time=getTime() }
        if #capturedIDs.pkt_in > 50 then table.remove(capturedIDs.pkt_in,1) end
    end
    for _,v in ipairs(INCOMING_PACKET) do
        if id==v[1] then
            if v.nop then return false end
            if v.hook and RakNet.hook.inpacket.selected then
                local data = getBitstream(INCOMING_PACKET[RakNet.hook.inpacket.selected])
                applyHook(bs, RakNet.hook.inpacket.slots, data)
                return {id,bs}
            end
        end
    end
end)

--=============================================================
-- \xce\xf1\xed\xee\xe2\xed\xee\xe9 \xf6\xe8\xea\xeb
--=============================================================

function onScriptTerminate(scr, quitGame)
    if quitGame and config.logs.quitGameClean[0] then
        local f = io.open("raklog/raklog.txt","w+"); f:close()
    end
end

function main()
    while RakLua.getSampVersion()==nil do wait(0) end

    sampRegisterChatCommand("rak", function()
        config.mainWindow[0] = not config.mainWindow[0]
    end)

    sampAddChatMessage("\xd0\xe0\xea\xcd\xe5\xf2 \xc7\xe0\xec\xe5\xed\xf8\xe8\xea \xe7\xe0\xe3\xf0\xf3\xe6\xe5\xed. \xce\xf2\xea\xf0\xfb\xf2\xfc: /rak", -1)

    while true do
        wait(0)

        -- \xdd\xf4\xf4\xe5\xea\xf2 \xfd\xef\xe5\xf0\xe5\xf5\xee\xe4\xe0 \xed\xee\xf2\xe8\xf4\xe8\xea\xe0\xf6\xe8\xe9
        for k=#list,1,-1 do
            local d = list[k]
            if d then
                if d.alpha==nil then list[k].alpha=0 end
                local dt = os.clock()-d.start
                if dt < 0.5 then
                    list[k].alpha = bringFloatTo(0, 1, d.start, 0.5)
                elseif d.time-0.5 < dt then
                    list[k].alpha = bringFloatTo(1, 0, d.start+d.time-0.5, 0.5)
                end
                if dt > d.time then table.remove(list,k) end
            end
        end

        -- \xc2\xee\xf1\xef\xf0\xee\xe8\xe7\xe2\xe5\xe4\xe5\xed\xe8\xe5 \xf1\xf6\xe5\xed\xe0\xf0\xe8\xe5\xe2
        for _, sc in ipairs(RakNet.scenarios) do
            if sc.play then
                for _, slot in ipairs(sc.slots) do
                    emulData(slot.id, slot.type, slot.data, true)
                end
                if sc.loop then
                    wait(sc.wait)
                else
                    sc.play = false
                end
            end
        end
    end
end
