script_name("RakNet Changer RU")
script_author("Ega / UI-edit")
script_description("\xc8\xed\xf1\xf2\xf0\xf3\xec\xe5\xed\xf2 \xe4\xeb\xff \xf0\xe0\xe1\xee\xf2\xfb \xf1 SA-MP \xef\xe0\xea\xe5\xf2\xe0\xec\xe8 \xe8 RPC")
