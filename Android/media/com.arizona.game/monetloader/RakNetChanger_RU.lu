local inicfg   = require("inicfg")
local ffi      = require("ffi")
local imgui    = require("mimgui")
local encoding = require("encoding")

local ok, RakLua = pcall(require, "RakLua")
if not ok then
    local gta = ffi.load('GTASA')
    ffi.cdef[[ void _Z12AND_OpenLinkPKc(const char* link); ]]
    sampAddChatMessage("\xd0\xe0\xea\xcd\xe5\xf2 \xc7\xe0\xec\xe5\xed\xf8\xe8\xea: RakLua \xed\xe5 \xed\xe0\xe9\xe4\xe5\xed! \xd3\xf1\xf2\xe0\xed\xee\xe2\xe8\xf2\xe5 \xef\xee: https://t.me/monetbinder/88", -1)
    gta._Z12AND_OpenLinkPKc("https://t.me/monetbinder/88")
    return
end

local fa  = require("fAwesome6_solid")
local lfs = require("lfs")

--=============================================================
-- \xca\xee\xed\xf4\xe8\xe3
--=============================================================

local mainIni = inicfg.load({
    config = {
        twist              = 0,
        style              = 0,
        notifications      = true,
        hints              = true,
        logs               = true,
        logs_quitGameClean = false,
        logs_outrpc        = false,
        logs_inrpc         = false,
        logs_outpacket     = false,
        logs_inpacket      = false,
        logs_scenario      = false,
        menu_keys          = "[122]"
    }
}, "raknet.ini")

if not doesFileExist("config/raknet.ini") then inicfg.save(mainIni, "raknet.ini") end

if mainIni.config.logs then
    if not doesDirectoryExist("raklog") then createDirectory("raklog") end
    if not doesFileExist("raklog/raklog.txt") then
        local f = io.open("raklog/raklog.txt", "w"); f:close()
    end
end

