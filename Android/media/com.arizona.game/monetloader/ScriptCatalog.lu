    CARD        = imgui.ImVec4(0.09, 0.09, 0.13, 1.00),
    CARD_HOV    = imgui.ImVec4(0.12, 0.12, 0.17, 1.00),
    ACCENT      = imgui.ImVec4(1.00, 0.50, 0.05, 1.00),
    ACCENT2     = imgui.ImVec4(0.20, 0.70, 1.00, 1.00),
    VIP_GOLD    = imgui.ImVec4(1.00, 0.82, 0.10, 1.00),
    FREE_GREEN  = imgui.ImVec4(0.15, 0.85, 0.45, 1.00),
    TEXT        = imgui.ImVec4(0.95, 0.95, 0.95, 1.00),
    TEXT_DIM    = imgui.ImVec4(0.55, 0.55, 0.60, 1.00),
    BORDER      = imgui.ImVec4(0.18, 0.18, 0.25, 1.00),
    BTN         = imgui.ImVec4(1.00, 0.50, 0.05, 1.00),
    BTN_HOV     = imgui.ImVec4(1.00, 0.65, 0.20, 1.00),
    BTN_ACT     = imgui.ImVec4(0.80, 0.38, 0.02, 1.00),
